[Unit]
Description=PROJECT01 Coordinator API
After=network-online.target redis-server.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/project01/coordinator
EnvironmentFile=/opt/project01/config/.env
ExecStart=/opt/project01/coordinator/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
