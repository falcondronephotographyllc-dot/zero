[Unit]
Description=PROJECT01 Telegram Bot
After=network-online.target project01-coordinator.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/project01/coordinator
EnvironmentFile=/opt/project01/config/.env
ExecStart=/opt/project01/coordinator/.venv/bin/python -m app.telegram_bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
